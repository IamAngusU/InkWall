# InkWall runtime config
# Copy to .env and fill only the provider you want to use.

# off | auto | on
# auto enables AI when a configured OpenAI, DeepSeek, or Ollama provider is found.
INKWALL_AI_MODERATION=auto

# auto | local | openai_moderation | deepseek | ollama
INKWALL_AI_PROVIDER=auto
# Optional channel split. Empty means use INKWALL_AI_PROVIDER.
# Example: DeepSeek for text, OpenAI moderation for images.
INKWALL_AI_TEXT_PROVIDER=
INKWALL_AI_IMAGE_PROVIDER=

# Cost guard for paid or local AI moderation.
# When a quota is reached, submissions go to manual review without another AI call.
INKWALL_AI_VISITOR_HOURLY_LIMIT=5
INKWALL_AI_GLOBAL_HOURLY_LIMIT=40
# 0 disables the daily counter. DeepSeek uses the balance guard below by default.
INKWALL_AI_GLOBAL_DAILY_LIMIT=0
INKWALL_AI_IMAGE_HOURLY_LIMIT=12

# Review mail for notes that need manual approval.
INKWALL_REVIEW_EMAIL=you@example.com
INKWALL_ADMIN_URL=https://example.com/admin/inkwall.php
INKWALL_PUBLIC_URL=https://example.com/inkwall
MAIL_FROM=hello@example.com
MAIL_FROM_NAME=InkWall
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=hello@example.com
MAIL_PASSWORD=

# OpenAI moderation: text + supported image inputs.
OPENAI_API_KEY=
INKWALL_AI_MODERATION_MODEL=omni-moderation-latest

# DeepSeek: OpenAI-compatible moderation prompt.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
INKWALL_DEEPSEEK_MODEL=deepseek-v4-flash
# Checks /user/balance before model calls. If the check fails or balance is low, the note goes to review.
INKWALL_DEEPSEEK_BALANCE_GUARD=1
INKWALL_DEEPSEEK_MIN_BALANCE_USD=0.25
INKWALL_DEEPSEEK_DAILY_SPEND_LIMIT_USD=1.00
INKWALL_DEEPSEEK_ESTIMATED_CALL_USD=0.01
INKWALL_DEEPSEEK_BALANCE_CACHE_SECONDS=60
INKWALL_DEEPSEEK_BALANCE_FAIL_CLOSED=1
INKWALL_DEEPSEEK_TRACK_BALANCE_AFTER_CALL=1
# Experimental: only enable if your selected DeepSeek model/API accepts OpenAI-style image content.
INKWALL_DEEPSEEK_SEND_IMAGES=0

# Ollama: local text moderation prompt.
# Example: ollama pull qwen3:latest
INKWALL_OLLAMA_URL=http://127.0.0.1:11434
INKWALL_OLLAMA_MODEL=qwen3:latest

# Text-only providers cannot inspect images. Keep this off for public surfaces:
# image submissions then get an audit flag unless OpenAI moderation or another vision provider is used.
INKWALL_AI_ALLOW_UNCHECKED_IMAGES=0
# If 1, that audit flag becomes actionable and sends image submissions to review.
INKWALL_AI_REVIEW_UNCHECKED_IMAGES=0

# AI flag policy: allow | hold | reject.
# Reject is only final when INKWALL_AI_ALLOW_REJECT=1; otherwise it becomes hold.
INKWALL_AI_ALLOW_REJECT=0
INKWALL_AI_FLAG_POLICY_JSON={"advertising":"allow","harassment":"hold","copyright":"hold","violence":"hold","nudity":"hold"}
# Optional single-flag override:
# INKWALL_AI_FLAG_ADVERTISING=allow

# SVG rendering.
INKWALL_BRANDING_JSON={"accent":"#d7422f","paper_texture":"dots","theme":"light","ad_badge":true,"ad_badge_text":"ADS","review_badge":true,"review_badge_mode":"auto","review_badge_text":"Reviewed automatically","review_badge_model_prefix":"Approved by","owner_name":"Angus Uelsmann","profile_url":"https://github.com/IamAngusU","repository_url":"https://github.com/IamAngusU/InkWall","site_url":"https://angusu.de/inkwall","site_label":"angusu.de/inkwall","image_rendering":"ink"}
# Optional single-value overrides:
# INKWALL_BRAND_ACCENT=#2ec4b6
# INKWALL_BRAND_PAPER_TEXTURE=dots
# INKWALL_BRAND_THEME=light
# INKWALL_BRAND_AD_BADGE=1
# INKWALL_BRAND_AD_BADGE_TEXT=AD
# INKWALL_BRAND_REVIEW_BADGE=1
# INKWALL_BRAND_REVIEW_BADGE_MODE=auto
# INKWALL_BRAND_REVIEW_BADGE_TEXT=Reviewed automatically
# INKWALL_BRAND_REVIEW_BADGE_MODEL_PREFIX=Approved by
# INKWALL_BRAND_OWNER_NAME=Angus Uelsmann
# INKWALL_BRAND_PROFILE_URL=https://github.com/IamAngusU
# INKWALL_BRAND_REPOSITORY_URL=https://github.com/IamAngusU/InkWall
# INKWALL_BRAND_SITE_URL=https://example.com/inkwall
# INKWALL_BRAND_SITE_LABEL=example.com/inkwall
# ink image_rendering uses four-tone display mapping; natural keeps normal image colors while still compressing.
# INKWALL_BRAND_IMAGE_RENDERING=ink
INKWALL_SVG_EMOJI_STYLE=native
INKWALL_SVG_FOOTER_LINKS=1
INKWALL_SVG_CLICKABLE_LINKS=1
INKWALL_SVG_AD_BADGE=1
INKWALL_SVG_REVIEW_BADGE=1
